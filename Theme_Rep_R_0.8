            '<input id="w_position" type="submit" value="サブウインドウ位置設定">'+
            '<input id="blog_setting" type="submit" value="テーマ編集"></div>'+
            '<style>#trep_panel { position: fixed; z-index: 100; top: 60px; left: 60px; '+
